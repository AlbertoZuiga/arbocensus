# Copy to .env and fill in. Loaded by docker-compose (env_file) and Django (settings.py).

DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,backend

DB_NAME=arbocensus
DB_USER=arbocensus
DB_PASSWORD=your-db-password
DB_HOST=db
DB_PORT=5432

# Host ports for locally exposed services (container ports are fixed)
BACKEND_PORT=8000
DB_HOST_PORT=5433
FRONTEND_PORT=5173

REDIS_URL=redis://redis:6379/0
OSRM_URL=http://osrm:5000

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

JWT_ACCESS_LIFETIME_MINUTES=60
JWT_REFRESH_LIFETIME_DAYS=7

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@arbocensus.cl
DJANGO_SUPERUSER_PASSWORD=change-me

# Dev seed (runs idempotently on container start; set SEED_DEV=false to disable)
SEED_DEV=true
SEED_ADMIN_COUNT=1
SEED_SURVEYOR_COUNT=2
SEED_USER_PASSWORD=arbocensus
SEED_DEV_DATASET_NAME=Dev Seed
SEED_DEV_TREES=15

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
